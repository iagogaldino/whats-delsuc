# Opcional (fallback no servidor). A chave principal é por conta: menu Chave IA na aplicação.
OPENAI_API_KEY=
# API SaaS WhatsApp Connect (sem trailing slash). Producao:
#   https://whatsapp-connect.tech  -> auth em .../api/v1/auth/login
# Dev local (se seu SaaS roda na maquina): http://localhost:3001
WHATSAPP_CONNECT_BASE_URL=https://whatsapp-connect.tech
WHATSAPP_CONNECT_API_KEY=
WHATSAPP_CONNECT_EMAIL=conta_whatsapp_connect@exemplo.com
WHATSAPP_CONNECT_PASSWORD=Senha@123456
# Base URL publica do backend. O sistema monta automaticamente: <base>/webhooks/whatsapp
# Exemplo: https://seu-backend.com
INSTANCE_WEBHOOK_BASE_URL=https://seu-backend.com
# Legacy (opcional): URL completa pronta, se preferir manter compatibilidade.
# INSTANCE_WEBHOOK_URL=https://seu-backend.com/webhooks/whatsapp
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d
PORT=3333

VITE_API_URL=http://localhost:3333
